# ──────────────────────────────
# MongoDB Atlas (replace creds)
# ──────────────────────────────
#MONGO_URI=mongodb://host.docker.internal:27017/
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=astra

# ──────────────────────────────
# RabbitMQ (shared with RainaV2)
# ──────────────────────────────
# By default points to the host’s RabbitMQ (works with Docker Desktop & Linux with host-gateway mapping).
# Change user/pass if your RainaV2 broker uses different credentials.
RABBITMQ_URI=amqp://raina:raina@host.docker.internal:5672/
RABBITMQ_EXCHANGE=raina.events

# ──────────────────────────────
# Event org segments
# ──────────────────────────────
EVENTS_ORG=astra
PLATFORM_EVENTS_ORG=platform

# ──────────────────────────────
# Consumer queue (durable)
# ──────────────────────────────
# Use "" for ephemeral/auto-delete queues during dev.
CONSUMER_QUEUE_WORKSPACE=platform.workspace.v1
