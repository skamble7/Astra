# ──────────────────────────────
# MongoDB
# ──────────────────────────────
MONGO_URI=mongodb+srv://sandeepk:sandeep@cluster0.tnbpi.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB=astra

# ──────────────────────────────
# RabbitMQ (shared)
# ──────────────────────────────
RABBITMQ_URI=amqp://raina:raina@host.docker.internal:5672/
RABBITMQ_EXCHANGE=raina.events

# ──────────────────────────────
# Event org segments
# ──────────────────────────────
EVENTS_ORG=astra
PLATFORM_EVENTS_ORG=platform

# ──────────────────────────────
# Downstream service endpoints
# ──────────────────────────────
CAPABILITY_SVC_BASE_URL=http://host.docker.internal:9021
ARTIFACT_SVC_BASE_URL=http://host.docker.internal:9020

# ──────────────────────────────
# HTTP client
# ──────────────────────────────
HTTP_CLIENT_TIMEOUT_SECONDS=30

# ──────────────────────────────
# Service identity / logging
# ──────────────────────────────
SERVICE_NAME=conductor-service
LOG_LEVEL=INFO

# ──────────────────────────────
# LLM driving the conductor agent
# ──────────────────────────────
# Supported providers: openai, gemini
#LLM_PROVIDER=gemini
LLM_PROVIDER=openai

# Conductor's API key (for agent orchestration)
# For OpenAI: starts with sk-proj- or sk-
# For Gemini: starts with AIza
LLM_API_KEY=your-api-key-here

# Model configuration (provider-specific)
# For OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo, etc.
# For Gemini: gemini-1.5-flash-latest, gemini-1.5-pro-latest, gemini-1.0-pro
#LLM_MODEL=gemini-flash-latest
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000
LLM_STRICT_JSON=1

# Override capability LLM settings (development/testing)
# When set to 1, ALL capabilities will use conductor's LLM settings above
# When set to 0 (default), each capability uses its own provider/model/auth
# Useful for: testing, cost control, demos, or forcing single provider
OVERRIDE_CAPABILITY_LLM=0

# ──────────────────────────────
# Provider-Specific API Keys (for capabilities)
# ──────────────────────────────
# Capabilities specify provider in their config (openai, gemini, etc.)
# The resolver automatically maps PROVIDER_API_KEY to these based on provider field
OPENAI_API_KEY=sk-proj-your-openai-key-here
GEMINI_API_KEY=AIza-your-gemini-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
COHERE_API_KEY=your-cohere-key-here
AZURE_OPENAI_API_KEY=your-azure-openai-key-here


# ──────────────────────────────
# Secret resolution
# ──────────────────────────────
SECRET_BACKEND=env
SECRET_ALIAS_PREFIX=ASTRA_SECRET_

# Legacy/Namespaced aliases (optional - for backwards compatibility)
# Capabilities now use PROVIDER_API_KEY which auto-resolves to provider-specific keys above
ASTRA_SECRET_OPENAI_API_KEY=${OPENAI_API_KEY}
ASTRA_SECRET_GEMINI_API_KEY=${GEMINI_API_KEY}
ASTRA_SECRET_ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}